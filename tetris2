/* ================================================================
 *  DATA STRUCTURES  (Core DSA concepts)
 * ================================================================ */

/*
 * Piece — the currently active falling tetromino.
 *
 *   shape[4][4] : local copy of the current rotation grid
 *   row, col    : top-left corner position on the board
 *   type        : index 0-6 into SHAPES[]
 *   rot         : rotation state 0-3
 */
typedef struct {
    int shape[4][4];
    int row, col;
    int type;
    int rot;
} Piece;

/*
 * Queue — Circular Array Queue  (DSA: Queue ADT)
 *
 * Used for: next-piece preview (holds up to Q_CAP piece types).
 *
 * Circular indexing prevents wasted space:
 *   Enqueue → rear  = (rear  + 1) % Q_CAP
 *   Dequeue → front = (front + 1) % Q_CAP
 *   Full    → count == Q_CAP
 *   Empty   → count == 0
 */
typedef struct {
    int data[Q_CAP];
    int front, rear, count;
} Queue;

/*
 * Node — Singly Linked List node  (DSA: Linked List)
 *
 * Used for: the leaderboard, sorted in descending score order.
 * Each node points to the next; the last node's next == NULL.
 */
typedef struct Node {
    char        name[NAME_LEN];
    int         score;
    struct Node *next;     /* pointer to next node in list */
} Node;

/*
 * Game — master state structure.
 *
 *   board[ROWS][COLS] : 2-D array; 0 = empty, 1-7 = locked type+1
 *   cur               : active falling piece
 *   nextQ             : circular queue of upcoming piece types
 *   leaders           : head of leaderboard linked list
 *   holdType          : type index of held piece (-1 = none)
 *   holdUsed          : 1 if hold already used this drop
 *   level             : increases every LINES_PER_LVL lines
 *   combo             : consecutive-clear streak (bonus scoring)
 *   gameOver          : 1 when game ends
 *   playerName        : the current player's name
 */
typedef struct {
    int   board[ROWS][COLS];
    Piece cur;
    Queue nextQ;
    Node *leaders;
    int   score;
    int   lines;
    int   level;
    int   combo;
    int   holdType;
    int   holdUsed;
    int   gameOver;
    char  playerName[NAME_LEN];
} Game;

