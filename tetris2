/* ================================================================
 *  QUEUE OPERATIONS   (DSA: Circular Array Queue)
 * ================================================================ */

/* Initialise queue to empty state */
static void qInit(Queue *q) {
    q->front = q->rear = q->count = 0;
}

static int qEmpty(const Queue *q) { return q->count == 0; }
static int qFull (const Queue *q) { return q->count == Q_CAP; }

/*
 * qPush — enqueue a value at the rear.
 * rear advances circularly: rear = (rear + 1) % Q_CAP
 */
static void qPush(Queue *q, int v) {
    if (qFull(q)) return;
    q->data[q->rear] = v;
    q->rear = (q->rear + 1) % Q_CAP;
    q->count++;
}

/*
 * qPop — dequeue and return the front value.
 * front advances circularly: front = (front + 1) % Q_CAP
 */
static int qPop(Queue *q) {
    int v;
    if (qEmpty(q)) return -1;
    v = q->data[q->front];
    q->front = (q->front + 1) % Q_CAP;
    q->count--;
    return v;
}

/*
 * qPeek — read the i-th item from the front WITHOUT removing it.
 * Used to display the upcoming pieces preview.
 */
static int qPeek(const Queue *q, int i) {
    if (i >= q->count) return -1;
    return q->data[(q->front + i) % Q_CAP];
}

/* ================================================================
 *  LINKED LIST OPERATIONS   (DSA: Singly Linked List)
 * ================================================================ */

/*
 * listInsert — sorted insert into descending-score linked list.
 *
 * Algorithm (O(n) time):
 *   1. Allocate new node.
 *   2. If list empty OR new score is highest → insert at head.
 *   3. Else walk until cur->next->score < new score → splice in.
 *
 * Returns the (possibly new) head pointer.
 */
static Node *listInsert(Node *head, const char *name, int score) {
    Node *newNode;
    Node *cur;

    newNode = (Node *)malloc(sizeof(Node));
    if (!newNode) return head;          /* malloc guard */

    strncpy(newNode->name, name, NAME_LEN - 1);
    newNode->name[NAME_LEN - 1] = '\0';
    newNode->score = score;
    newNode->next  = NULL;

    /* Insert at head: empty list or highest score */
    if (!head || score > head->score) {
        newNode->next = head;
        return newNode;
    }

    /* Walk to the correct position */
    cur = head;
    while (cur->next && cur->next->score >= score)
        cur = cur->next;

    /* Splice in */
    newNode->next = cur->next;
    cur->next     = newNode;
    return head;
}

/*
 * listSave — write top MAX_SCORES entries to SCORE_FILE.
 * Each line: "name score\n"
 * BUG WARNING: use "\n" (newline), NOT "\\n" (backslash + n).
 */
static void listSave(Node *head) {
    FILE *fp;
    int   cnt = 0;

    fp = fopen(SCORE_FILE, "w");
    if (!fp) return;

    while (head && cnt < MAX_SCORES) {
        fprintf(fp, "%s %d\n", head->name, head->score);
        head = head->next;
        cnt++;
    }
    fclose(fp);
}

/*
 * listLoad — read SCORE_FILE and rebuild sorted linked list.
 * Returns head pointer (NULL if file not found or empty).
 */
static Node *listLoad(void) {
    FILE *fp;
    Node *head = NULL;
    char  name[NAME_LEN];
    int   score;

    fp = fopen(SCORE_FILE, "r");
    if (!fp) return NULL;

    while (fscanf(fp, "%19s %d", name, &score) == 2)
        head = listInsert(head, name, score);

    fclose(fp);
    return head;
}

/* Free every node to prevent memory leak */
static void listFree(Node *head) {
    Node *t;
    while (head) {
        t    = head;
        head = head->next;
        free(t);
    }
}

