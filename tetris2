    clearScreen();

Game g;
int tickCounter = 0;
int delay;
int i;

srand((unsigned)time(NULL));

/* Splash + name */
drawSplash();
if (scanf("%19s", g.playerName) != 1)
    strcpy(g.playerName, "Player");

/* Countdown */
for (i = 3; i >= 1; i--) {
    clearScreen();
    printf("\n\n\n");
    printf("Get ready, %s!\n\n", g.playerName);
    printf("   %d...\n", i);
    fflush(stdout);
    SLEEP_MS(700);
}

/* INIT GAME PROPERLY */
gameInit(&g);   // ✅ DO NOT memset again

clearScreen();

    /*
     * ── Main game loop ──
     *
     * Each iteration:
     *   1. Handle keyboard input (non-blocking)
     *   2. Count frames; apply gravity when enough frames elapsed
     *   3. Render the frame
     *   4. Sleep FRAME_MS milliseconds (~20 fps)
     */
    delay = calcDelay(g.level);
    while (!g.gameOver) {
        handleInput(&g);

        /* Gravity: fire every (delay / FRAME_MS) frames */
        tickCounter++;
        if (tickCounter >= delay / FRAME_MS) {
            tick(&g);
            tickCounter = 0;
            delay = calcDelay(g.level);   /* recalc after level change */
        }

        draw(&g);
        SLEEP_MS(FRAME_MS);
    }

    /* ── End of game ── */
    showCursor();
    g.leaders = listInsert(g.leaders, g.playerName, g.score);
    listSave(g.leaders);
    drawGameOver(&g);
    listFree(g.leaders);

    /* Wait for Enter key */
    {
        int ch;
        while ((ch = getchar()) != '\n' && ch != EOF);
        getchar();
    }

    clearScreen();
    showCursor();
    printf(FG_CYAN "  Thanks for playing! Goodbye.\n\n" RESET);
    return 0;
}
