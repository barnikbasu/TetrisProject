/* ================================================================
 *  PIECE HELPERS
 * ================================================================ */

/*
 * shapeLoad — copy current rotation from global SHAPES into p->shape.
 * Must be called whenever p->type or p->rot changes.
 */
static void shapeLoad(Piece *p) {
    int r, c;
    for (r = 0; r < 4; r++)
        for (c = 0; c < 4; c++)
            p->shape[r][c] = SHAPES[p->type][p->rot][r][c];
}

/*
 * fits — collision and bounds check.
 *
 * Parameters:
 *   dr, dc  : proposed row/col displacement
 *   newRot  : proposed rotation index
 *
 * Returns 1 if piece can move there, 0 if blocked.
 *
 * Checks each filled cell against:
 *   • Left/right walls  (bc < 0 || bc >= COLS)
 *   • Floor             (br >= ROWS)
 *   • Locked board cell (g->board[br][bc] != 0)
 * Cells above row 0 (spawn zone) are skipped.
 */
static int fits(const Game *g, const Piece *p,
                int dr, int dc, int newRot) {
    int r, c;
    for (r = 0; r < 4; r++) {
        for (c = 0; c < 4; c++) {
            int br, bc;
            if (!SHAPES[p->type][newRot][r][c]) continue;
            br = p->row + r + dr;
            bc = p->col + c + dc;
            if (bc < 0 || bc >= COLS) return 0;
            if (br >= ROWS)           return 0;
            if (br < 0)               continue; /* above board */
            if (g->board[br][bc])     return 0;
        }
    }
    return 1;
}

/*
 * ghostRow — find the lowest row the piece would reach if dropped.
 * Used to draw the "ghost" outline below the active piece.
 */
static int ghostRow(const Game *g) {
    int drop = 0;
    while (fits(g, &g->cur, drop + 1, 0, g->cur.rot))
        drop++;
    return g->cur.row + drop;
}

/* ================================================================
 *  GAME LOGIC
 * ================================================================ */

/*
 * fillQueue — top up the preview queue with random piece types
 * until it reaches Q_CAP.
 */
static void fillQueue(Game *g) {
    while (!qFull(&g->nextQ))
        qPush(&g->nextQ, rand() % 7);
}

/*
 * spawnPiece — pull the next type from the queue and place it.
 *
 * NOTE: After qPop, queue has one free slot → immediately push
 *       a new random type to keep the queue full.
 *       (Bug in the document version: it didn't refill after pop.)
 *
 * Sets gameOver = 1 if the new piece overlaps locked cells (top-out).
 */
static void spawnPiece(Game *g) {
    int type;
    fillQueue(g);
int type = qPop(&g->nextQ);
if (type == -1) type = rand() % 7;
qPush(&g->nextQ, rand() % 7);

    g->cur.type = type;
    g->cur.rot  = 0;
    g->cur.row  = 0;
    g->cur.col  = COLS / 2 - 2;
    shapeLoad(&g->cur);
    g->holdUsed = 0;

    if (!fits(g, &g->cur, 0, 0, g->cur.rot))
        g->gameOver = 1;
}

/*
 * holdPiece — swap current piece with the held piece.
 *
 * DSA note: behaves like a 1-slot Stack (push & pop in one step).
 *
 * Rules:
 *   • holdUsed flag: you can only hold ONCE per piece drop.
 *   • If nothing held: park current, spawn next.
 *   • If something held: swap current ↔ held.
 *
 * (Completely missing from the document's main() — added here.)
 */
static void holdPiece(Game *g) {
    int cur, prev;
    if (g->holdUsed) return;    /* already used hold this turn */
    g->holdUsed = 1;
    cur = g->cur.type;

    if (g->holdType == -1) {
        /* First hold: nothing stored yet — park and spawn */
        g->holdType = cur;
        spawnPiece(g);
        g->holdUsed = 1;        /* spawnPiece resets it; force back */
    } else {
        /* Swap current with stored hold */
        prev        = g->holdType;
        g->holdType = cur;
        g->cur.type = prev;
        g->cur.rot  = 0;
        g->cur.row  = 0;
        g->cur.col  = COLS / 2 - 2;
        shapeLoad(&g->cur);
        if (!fits(g, &g->cur, 0, 0, g->cur.rot))
            g->gameOver = 1;
    }
}

/*
 * lockAndClear — lock the piece onto the board, clear full rows,
 *               update score/lines/level.
 *
 * Classic Tetris scoring × level multiplier:
 *   1 line  →  100 × level
 *   2 lines →  300 × level
 *   3 lines →  500 × level
 *   4 lines →  800 × level  (Tetris!)
 *   combo bonus: +50 × combo_count × level (consecutive clears)
 *
 * (Document used "cleared² × 100" which breaks Tetris scoring.)
 */
static void lockAndClear(Game *g) {
    int r, c, cleared;
    int base[5] = {0, 100, 300, 500, 800};

    /* Step 1: write piece cells to board (value = type + 1) */
    for (r = 0; r < 4; r++) {
        for (c = 0; c < 4; c++) {
            if (g->cur.shape[r][c]) {
                int br = g->cur.row + r;
                int bc = g->cur.col + c;
                if (br >= 0 && br < ROWS && bc >= 0 && bc < COLS)
                    g->board[br][bc] = g->cur.type + 1;
            }
        }
    }

    /* Step 2: scan rows bottom-up; remove full rows */
    cleared = 0;
    for (r = ROWS - 1; r >= 0; r--) {
        int full = 1;
        for (c = 0; c < COLS; c++)
            if (!g->board[r][c]) { full = 0; break; }

        if (full) {
            int i;
            cleared++;
            /* Shift every row above downward by one */
            for (i = r; i > 0; i--)
                memcpy(g->board[i], g->board[i-1], sizeof(g->board[i]));
            memset(g->board[0], 0, sizeof(g->board[0]));
            r++;    /* re-check this index — new row shifted in */
        }
    }

    /* Step 3: update score, lines, level, combo */
    if (cleared > 0) {
        int pts = base[cleared] * g->level;
        pts += 50 * g->combo * g->level;   /* combo bonus */
        g->score += pts;
        g->lines += cleared;
        g->combo++;
        g->level = (g->lines / LINES_PER_LVL) + 1;
    } else {
        g->combo = 0;   /* reset combo streak on no clear */
    }
}

/*
 * calcDelay — gravity period in ms based on level.
 * Decreases from BASE_DELAY toward MIN_DELAY as level rises.
 */
static int calcDelay(int level) {
    int d = BASE_DELAY - (level - 1) * 40;
    return (d < MIN_DELAY) ? MIN_DELAY : d;
}

