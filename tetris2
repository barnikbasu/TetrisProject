/*
 * drawGameOver — styled end screen with leaderboard.
 * Highlights the current player's entry with ◄ YOU.
 */
static void drawGameOver(Game *g) {
    Node *h;
    int   rank, i;

    clearScreen();
    printf("\n\n");
    printf(FG_RED BOLD "   ╔══════════════════════════════════════╗\n"  RESET);
    printf(FG_RED BOLD "   ║           G A M E  O V E R           ║\n"  RESET);
    printf(FG_RED BOLD "   ╚══════════════════════════════════════╝\n\n" RESET);

    printf(FG_WHITE   "   Player : " BOLD "%-18s\n" RESET, g->playerName);
    printf(FG_YELLOW  "   Score  : " BOLD "%-18d\n" RESET, g->score);
    printf(FG_GREEN   "   Lines  : " BOLD "%-18d\n" RESET, g->lines);
    printf(FG_CYAN    "   Level  : " BOLD "%-18d\n" RESET, g->level);
    printf(FG_LGRAY   "\n   ──────────────────────────────────────\n" RESET);
    printf(FG_YELLOW BOLD "   LEADERBOARD\n\n" RESET);

    h    = g->leaders;
    rank = 1;
    while (h && rank <= MAX_SCORES) {
        const char *col = (rank == 1) ? FG_YELLOW :
                          (rank == 2) ? FG_LGRAY  :
                          (rank == 3) ? FG_ORANGE : FG_DGRAY;
        /* Highlight own entry */
        if (strcmp(h->name, g->playerName) == 0 &&
            h->score == g->score)
            printf(FG_GREEN BOLD "   %2d.  %-16s  %-8d  ◄ YOU\n" RESET,
                   rank, h->name, h->score);
        else
            printf("%s   %2d.  %-16s  %d\n" RESET,
                   col, rank, h->name, h->score);
        h = h->next;
        rank++;
    }
    if (rank == 1)
        printf(FG_DGRAY "   (no scores yet)\n" RESET);

    printf(FG_LGRAY "\n   ──────────────────────────────────────\n" RESET);
    printf(FG_CYAN  "\n   ");
    for (i = 0; i < 3; i++) printf("· ");
    printf(BOLD "Press ENTER to exit" RESET FG_CYAN "  ");
    for (i = 0; i < 3; i++) printf("· ");
    printf(RESET "\n");
}

/* ================================================================
 *  MAIN RENDER  (called every frame)
 * ================================================================ */

/*
 * draw — render the complete game UI without clearing the screen.
 *
 * Technique: ANSI cursor repositioning (\033[row;colH) moves to
 * each section and overwrites in-place. This eliminates flicker
 * that system("clear") causes.
 *
 * Layout:
 *   Col  1      : board (left wall)
 *   Col  2-21   : board cells (10 cols × 2 chars each = 20)
 *   Col  22     : board (right wall)
 *   Col  25+    : side panel (score, preview, hold, controls)
 */
static void draw(Game *g) {
    /* ── Build composite display arrays ── */
    int temp[ROWS][COLS];   /* board + active piece overlay  */
    int isGhost[ROWS][COLS];/* marks ghost-only cells        */
    int r, c;
    int gRow = ghostRow(g);

    /* Start with locked board */
    for (r = 0; r < ROWS; r++)
        for (c = 0; c < COLS; c++) {
            temp[r][c]    = g->board[r][c];
            isGhost[r][c] = 0;
        }

    /* Overlay ghost cells (dim shadow of landing position) */
    for (r = 0; r < 4; r++) {
        for (c = 0; c < 4; c++) {
            if (g->cur.shape[r][c]) {
                int br = gRow + r;
                int bc = g->cur.col + c;
                if (br >= 0 && br < ROWS && bc >= 0 && bc < COLS
                    && temp[br][bc] == 0) {
                    isGhost[br][bc] = g->cur.type + 1;
                }
            }
        }
    }

    /* Overlay active piece (overwrites ghost if same cell) */
    for (r = 0; r < 4; r++) {
        for (c = 0; c < 4; c++) {
            if (g->cur.shape[r][c]) {
                int br = g->cur.row + r;
                int bc = g->cur.col + c;
                if (br >= 0 && br < ROWS && bc >= 0 && bc < COLS) {
                    temp[br][bc]    = g->cur.type + 1;
                    isGhost[br][bc] = 0;  /* not ghost here */
                }
            }
        }
    }

    /* ── Draw board ── */
    moveCursor(1, 1);
    printf(FG_WHITE "┌");
    printRepeat("──", COLS);
    printf("┐" RESET);

    for (r = 0; r < ROWS; r++) {
        moveCursor(r + 2, 1);
        printf(FG_WHITE "│" RESET);
        for (c = 0; c < COLS; c++) {
            if (isGhost[r][c]) {
                /* Ghost cell: dim outline of landing position */
                printf(DIM FG_DGRAY "░░" RESET);
            } else if (temp[r][c]) {
                /* Filled cell: coloured block */
                printf("%s  " RESET, PIECE_COLORS[temp[r][c] - 1]);
            } else {
                /* Empty cell: subtle dot for grid feel */
                printf(FG_DGRAY "· " RESET);
            }
        }
        printf(FG_WHITE "│" RESET);
    }

    moveCursor(ROWS + 2, 1);
    printf(FG_WHITE "└");
    printRepeat("──", COLS);
    printf("┘" RESET);

    /* ── Right panel ── */
    {
        int pc  = COLS * 2 + 4;   /* panel start column */
        int pr  = 1;              /* panel start row    */

        /* Title */
        moveCursor(pr,     pc); printf(FG_CYAN BOLD "╔══════════════════╗"RESET);
        moveCursor(pr + 1, pc); printf(FG_CYAN BOLD "║" FG_WHITE "    T E T R I S   "FG_CYAN"║"RESET);
        moveCursor(pr + 2, pc); printf(FG_CYAN BOLD "╚══════════════════╝"RESET);

        /* Player */
        moveCursor(pr + 3, pc);
        printf(FG_DGRAY "Player: "FG_WHITE BOLD"%-10s"RESET, g->playerName);

        /* Score box */
        moveCursor(pr + 5, pc);
        printf(FG_YELLOW "┌──────────────────┐"RESET);
        moveCursor(pr + 6, pc);
        printf(FG_YELLOW "│ "BOLD"SCORE             "RESET FG_YELLOW"│"RESET);
        moveCursor(pr + 7, pc);
        printf(FG_YELLOW "│ "FG_WHITE BOLD"%-16d"RESET FG_YELLOW" │"RESET, g->score);
        moveCursor(pr + 8, pc);
        printf(FG_YELLOW "└──────────────────┘"RESET);

        /* Level and Lines */
        moveCursor(pr + 9, pc);
        printf(FG_GREEN "  LEVEL "FG_WHITE BOLD"%-4d"RESET
               FG_CYAN  "  LINES "FG_WHITE BOLD"%-4d"RESET,
               g->level, g->lines);

        /* Combo indicator */
        moveCursor(pr + 10, pc);
        if (g->combo > 1)
            printf(FG_ORANGE BOLD "  ★ COMBO x%-9d"RESET, g->combo);
        else
            printf("%-20s", "");

        /* Level-up progress bar */
        {
            int prog = g->lines % LINES_PER_LVL;
            int i;
            moveCursor(pr + 11, pc);
            printf(FG_DGRAY "  LVL ["RESET);
            for (i = 0; i < LINES_PER_LVL; i++)
                printf(i < prog ? FG_GREEN"█"RESET : FG_DGRAY"░"RESET);
            printf(FG_DGRAY"] %d/%d  "RESET, prog, LINES_PER_LVL);
        }

        /* Next pieces preview */
        moveCursor(pr + 13, pc);
        printf(FG_CYAN "  ┌──────────────────┐"RESET);
        moveCursor(pr + 14, pc);
        printf(FG_CYAN "  │  "FG_WHITE BOLD"NEXT PIECES"RESET FG_CYAN"     │"RESET);
        moveCursor(pr + 15, pc);
        printf(FG_CYAN "  └──────────────────┘"RESET);
        {
            int i;
            for (i = 0; i < 3; i++) {
                int t = qPeek(&g->nextQ, i);
                moveCursor(pr + 16 + i * 2, pc + 4);
                if (t >= 0)
                    printf("%s  "RESET" %s%-10s"RESET,
                           PIECE_COLORS[t],
                           PIECE_COLORS[t] ? FG_WHITE : "",
                           PIECE_NAME[t]);
                else
                    printf("%-16s", "");
            }
        }

        /* Hold piece */
        moveCursor(pr + 23, pc);
        printf(FG_MAGENTA "  ┌──────────────────┐"RESET);
        moveCursor(pr + 24, pc);
        printf(FG_MAGENTA "  │    "FG_WHITE BOLD"HOLD"RESET FG_MAGENTA"            │"RESET);
        moveCursor(pr + 25, pc);
        printf(FG_MAGENTA "  └──────────────────┘"RESET);
        moveCursor(pr + 26, pc + 4);
        if (g->holdType == -1)
            printf(FG_DGRAY "(empty)         "RESET);
        else
            printf("%s%s  "RESET" %-8s%s",
                   g->holdUsed ? DIM : "",
                   PIECE_COLORS[g->holdType],
                   PIECE_NAME[g->holdType],
                   g->holdUsed ? FG_DGRAY" (used)"RESET : "       ");

        /* Controls reference */
        moveCursor(pr + 28, pc);
        printf(FG_DGRAY "  ──────────────────"RESET);
        moveCursor(pr + 29, pc); printf(FG_DGRAY"  A/D"RESET"  Move");
        moveCursor(pr + 30, pc); printf(FG_DGRAY"  W  "RESET"  Rotate");
        moveCursor(pr + 31, pc); printf(FG_DGRAY"  S  "RESET"  Soft drop");
        moveCursor(pr + 32, pc); printf(FG_DGRAY"  SPC"RESET"  Hard drop");
        moveCursor(pr + 33, pc); printf(FG_DGRAY"  C  "RESET"  Hold");
        moveCursor(pr + 34, pc); printf(FG_DGRAY"  Q  "RESET"  Quit");

        /* DSA reminder for viva */
        moveCursor(pr + 36, pc);
        printf(FG_DGRAY"  Queue · Linked List · Array"RESET);
    }

    /* Park cursor below the board */
    moveCursor(ROWS + 4, 1);
    fflush(stdout);
}

/* ================================================================
 *  INPUT
 * ================================================================ */

/*
 * handleInput — process one waiting keypress (non-blocking).
 * Returns immediately if no key is available.
 *
 * Controls:
 *   A/D    → move left / right
 *   W      → rotate clockwise
 *   S      → soft drop (one row)
 *   Space  → hard drop (fall to bottom, then lock)
 *   C      → hold piece
 *   Q      → quit
 */
static void handleInput(Game *g) {
    int ch, newRot;
    if (!KB_HIT()) return;
    ch = GET_CH();

    /* Normalise to lowercase for convenience */
    if (ch >= 'A' && ch <= 'Z') ch += 32;

    switch (ch) {
        case 'a':
            if (fits(g, &g->cur, 0, -1, g->cur.rot)) g->cur.col--;
            break;
        case 'd':
            if (fits(g, &g->cur, 0, 1, g->cur.rot))  g->cur.col++;
            break;
        case 's':
            if (fits(g, &g->cur, 1, 0, g->cur.rot))  g->cur.row++;
            break;
        case 'w':
            newRot = (g->cur.rot + 1) % 4;
            if (fits(g, &g->cur, 0, 0, newRot)) {
                g->cur.rot = newRot;
                shapeLoad(&g->cur);
            }
            break;
        case ' ':   /* Hard drop */
            while (fits(g, &g->cur, 1, 0, g->cur.rot))
                g->cur.row++;
            lockAndClear(g);
            spawnPiece(g);
            break;
        case 'c':
            holdPiece(g);
            break;
        case 'q':
            g->gameOver = 1;
            break;
        default:
            break;
    }
}

/*
 * tick — one gravity step.
 * If piece can fall → drop it.
 * If blocked → lock it and spawn the next piece.
 */
static void tick(Game *g) {
    if (fits(g, &g->cur, 1, 0, g->cur.rot))
        g->cur.row++;
    else {
        lockAndClear(g);
        spawnPiece(g);
    }
}

/* ================================================================
 *  INITIALISATION
 * ================================================================ */

static void gameInit(Game *g) {
    memset(g->board, 0, sizeof(g->board));
    qInit(&g->nextQ);

    g->leaders  = listLoad();
    g->score    = 0;
    g->lines    = 0;
    g->level    = 1;
    g->combo    = 0;
    g->holdType = -1;
    g->holdUsed = 0;
    g->gameOver = 0;

    fillQueue(g);
    spawnPiece(g);
}

