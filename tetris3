static void gameInit(Game *g) {
    memset(g->board, 0, sizeof(g->board));
    qInit(&g->nextQ);

    g->leaders = listLoad();
    g->score = 0;
    g->lines = 0;
    g->holdType = -1;
    g->holdUsed = 0;
    g->gameOver = 0;

    fillQueue(g);
    spawnPiece(g);
}

int main(void) {
    Game g;
    char player[NAME_LEN];

    srand((unsigned)time(NULL));

    printf("Enter your name (one word, max 19 chars): ");
    if (scanf("%19s", player) != 1)
        strcpy(player, "Player");
    getchar();

    showTitleScreen();
    gameInit(&g);

    while (!g.gameOver) {
        handleInput(&g);
        tick(&g);
        draw(&g);
        SLEEP_MS(100);
    }

    clearScreen();
    printf("%s=========== GAME OVER ===========%s\n", CLR_RED, CLR_RESET);
    printf("Player       : %s\n", player);
    printf("Final Score  : %d\n", g.score);
    printf("Lines Cleared: %d\n", g.lines);

    g.leaders = listInsert(g.leaders, player, g.score);
    listSave(g.leaders);
    listPrint(g.leaders);
    listFree(g.leaders);

    return 0;
}
