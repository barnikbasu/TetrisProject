typedef struct {
    int shape[4][4];
    int row, col;
    int type;
    int rot;
} Piece;

typedef struct {
    int data[Q_CAP];
    int front, rear, count;
} Queue;

typedef struct Node {
    char name[NAME_LEN];
    int score;
    struct Node *next;
} Node;

typedef struct {
    int board[ROWS][COLS];
    Piece cur;
    Queue nextQ;
    Node *leaders;
    int score;
    int lines;
    int holdType;
    int holdUsed;
    int gameOver;
} Game;

